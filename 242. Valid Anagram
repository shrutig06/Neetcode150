//Used count array to store the frequency of characters in given strings s and t.
//TC: O(n+m) Space complexity: O(1) since we have at most 26 different characters.
class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.length()!=t.length()) return false;
        vector<int> v(26, 0);

        for(int i=0;i<s.length();i++){
            int idx1= s[i]-'a';
            int idx2=t[i]-'a';
            v[idx1]++; 
            v[idx2]--;
        }

        for(auto x:v){
            if(x!=0) return false;
        }
        return true;
    }
};


//Sort and compare the strings 
// Tc: O(nlogn + mlogm) Sc: O(1) or O(n + m) depending on the sorting algorithm.
class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.length()!=t.length()) return false;
       sort(s.begin(), s.end());
       sort(t.begin(), t.end());
       return s==t;
    }
};
