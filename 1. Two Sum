//Used vector find method to get index of target - nums[i]
// Time complexity: O(n^2) Space complexity: O(1)
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        vector<int> ans;
        for(int i=0;i<nums.size();i++){
            int x = nums[i];
          // find function in vector takes O(N) time for the lookup
            auto it = find(nums.begin(), nums.end(), target-nums[i]);
            int j=distance(nums.begin(), it);
            if(it!=nums.end() && i!=j){
                ans = {i,j};
                return ans;
            }
        }
        return ans;
    }
};


//Most optimal solution using hashmap 
// TC: O(N) SC: O(N)
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        vector<int> ans;
        unordered_map<int, int> mp;

        for(int i=0;i<nums.size();i++){
            int x=target-nums[i];
          // find function in map takes O(1) time
           auto it = mp.find(x); 
            if(it==mp.end()){
                mp.insert({nums[i], i});
            }else{
                ans={i, it->second};
            }
        }
        return ans;
    }
};
