Problem link -> https://leetcode.com/problems/contains-duplicate/description/

//Sort the array and check that the next and previous elements in the array should be the same.
// TC: O(nlogn) Sc: O(n) to store input array.
class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        for(int i=0;i<nums.size()-1;i++){
            if(nums[i]==nums[i+1]){
                return true;
            }
        }
        return false;
    }
};

//Used set to store distinct values, and then compare the nums array size should be equal to the set size if there are no duplicates.
//TC: O(n) Sc:O(n)
class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        return nums.size() > set<int>(nums.begin(), nums.end()).size();
    }
};

